DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DATABASE_URL=sqlite:///db.sqlite3
DEFAULT_FROM_EMAIL=HorizonBI <noreply@example.com>
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
TAILWIND_USE_CDN=True
STATIC_ROOT=staticfiles
MEDIA_ROOT=media
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
POWERBI_API_BASE_URL=https://api.powerbi.com/v1.0/myorg
POWERBI_AUTHORITY_URL=https://login.microsoftonline.com
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# TAILWIND_USE_CDN=True is intended only for quick local demos. Use False with a compiled CSS build for production-style deployments.
